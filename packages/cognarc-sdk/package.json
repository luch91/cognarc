{
  "name": "cognarc-sdk",
  "version": "0.1.0",
  "description": "CognArc behavioral instrumentation SDK — <8KB gzipped, zero PII",
  "main": "dist/cognarc-sdk.cjs",
  "module": "dist/cognarc-sdk.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cognarc-sdk.js",
      "require": "./dist/cognarc-sdk.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "test": "jest",
    "size": "size-limit",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "rollup": "^4.12.0",
    "size-limit": "^11.1.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "size-limit": [
    {
      "path": "dist/cognarc-sdk.js",
      "limit": "8 KB",
      "gzip": true
    }
  ]
}
